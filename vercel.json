{
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/v1/(.*)",
      "destination": "https://api.lydiacallcenter.org/v1/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://api.lydiacallcenter.org/admin/$1"
    },
    {
      "source": "/support-requests/(.*)",
      "destination": "https://api.lydiacallcenter.org/support-requests/$1"
    },
    {
      "source": "/api/admin/(.*)",
      "destination": "https://api.lydiacallcenter.org/api/admin/$1"
    },
    {
      "source": "/api/chat",
      "destination": "https://api.lydiacallcenter.org/v1/chat"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}